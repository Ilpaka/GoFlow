# Скопируйте в .env и подставьте свои значения. Не коммитьте .env с реальными секретами.

# Путь к YAML (по умолчанию configs/local.yaml относительно рабочей директории процесса).
# CONFIG_PATH=configs/local.yaml

# HTTP
HTTP_PORT=8080

# Postgres (для docker-compose см. значения в deployments/docker-compose.yml)
POSTGRES_DSN=postgres://messenger:messenger@localhost:5432/messenger?sslmode=disable

# Redis
REDIS_ADDR=localhost:6379

# JWT (каркас: значения загружаются в конфиг; выдача токенов — позже)
JWT_SECRET=local-dev-only-change-in-prod-min-16
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=604800

# Для docker-compose (образ postgres)
POSTGRES_USER=messenger
POSTGRES_PASSWORD=messenger
POSTGRES_DB=messenger
